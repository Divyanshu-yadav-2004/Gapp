# Server Configuration
PORT=3000
NODE_ENV=development

# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/easycafe?schema=public"

# Authentication Secrets
JWT_ACCESS_SECRET="super-secret-access-token-key-change-in-production-123456"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-change-in-production-789012"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Default Admin User
ADMIN_EMAIL="admin@easycafe.com"
ADMIN_PASSWORD="AdminPassword123!"

# Razorpay Payment Gateway Credentials (Test Mode)
RAZORPAY_KEY_ID="rzp_test_T93iiZ3axzlEqz"
RAZORPAY_KEY_SECRET="AwjxgWigNhOhCfCmDYHsAq7U"
RAZORPAY_WEBHOOK_SECRET="rzp_webhook_secret_test"
RAZORPAY_MODE="test"


# Email Configuration (Nodemailer SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_EMAIL="noreply@easycafe.com"
SMTP_FROM_NAME="EasyCafe Digital Service"

# AWS S3 / File Storage Config
UPLOAD_PROVIDER="local" # 'local' or 's3'
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET_NAME=""
AWS_S3_REGION="ap-south-1"

# CORS Allowed Origin
CORS_ORIGIN="http://localhost:5000,http://127.0.0.1:5000"
